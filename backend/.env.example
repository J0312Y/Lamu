# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=lamu_user
DB_PASSWORD=change-me
DB_NAME=lamu_admin

# ─── Security ─────────────────────────────────────────────────────────────────
API_ACCESS_KEY=change-this-secret-key

# ─── AI Provider (Lamu API mode) ──────────────────────────────────────────────
AI_CHAT_URL=https://api.openai.com/v1/chat/completions
AI_CHAT_API_KEY=sk-...

# ─── STT Provider (optional) ──────────────────────────────────────────────────
# STT_URL=https://api.openai.com/v1/audio/transcriptions
# STT_API_KEY=sk-...

# ─── Auto-updater ─────────────────────────────────────────────────────────────
# Uncomment and set when publishing a new release
# LATEST_VERSION=0.2.0
# APP_BASE_URL=https://cdn.lamuka.com/releases
# RELEASE_NOTES=Bug fixes and performance improvements

# ─── Monitoring alerts ────────────────────────────────────────────────────────
# Email address to receive provider health alerts (defaults to SMTP from address)
# ADMIN_ALERT_EMAIL=admin@yourdomain.com
